# =============================================================================
# Project 1: Literature Feed Automation environment template
# Copy this file to .env before running Docker Compose or local commands:
#   cp .env.example .env
# =============================================================================

# Optional Semantic Scholar API key. Leave empty unless you have one. The app throttles Semantic Scholar to about 1 request/second.
SEMANTIC_SCHOLAR_API_KEY=

# Optional email for OpenAlex polite pool/rate-limit contact.
OPENALEX_MAILTO=
# -----------------------------------------------------------------------------
# Ollama / LLM settings
# -----------------------------------------------------------------------------
# If you run Python locally outside Docker and Ollama is installed on your machine:
# OLLAMA_URL=http://localhost:11434/api/generate
#
# If the API runs inside Docker and should call your host/local Ollama:
OLLAMA_URL=http://host.docker.internal:11434/api/generate
#
# If you enable the Docker Ollama profile, use this instead:
# OLLAMA_URL=http://ollama:11434/api/generate

OLLAMA_MODEL=llama3.2:3b

# Optional OpenAI-compatible provider for future extensions.
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_MODEL=gpt-4o-mini

# -----------------------------------------------------------------------------
# API and n8n settings
# -----------------------------------------------------------------------------
RESEARCH_FEED_API_URL=http://localhost:8000/run_feed
TZ=Europe/Berlin
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_BASIC_AUTH_ACTIVE=false
N8N_BASIC_AUTH_USER=
N8N_BASIC_AUTH_PASSWORD=

# Docker bind-mount locations.
# For a self-contained production stack, keep these relative paths.
N8N_HOME=./.n8n
OLLAMA_HOME=./.ollama
